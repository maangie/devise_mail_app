<div class="hero-section text-center">
  <i class="bi bi-envelope-heart display-1 mb-3 d-block"></i>
  <h1 class="display-5 fw-bold">DeviseMailApp へようこそ！</h1>
  <p class="lead mb-0">メール認証付きのサンプルアプリです ✨</p>
</div>

<% if user_signed_in? %>
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card card-loggedin">
        <div class="card-body text-center py-4">
          <div class="card-icon-wrap">
            <i class="bi bi-person-check-fill"></i>
          </div>
          <h5 class="card-title fw-bold">ログイン中</h5>
          <p class="card-text text-muted mb-3">
            <i class="bi bi-envelope me-1"></i><%= current_user.email %>
          </p>
          <div class="d-flex justify-content-center gap-2 flex-wrap">
            <%= button_to destroy_user_session_path,
                  method: :delete,
                  class: 'btn btn-outline-danger px-4' do %>
              <i class="bi bi-box-arrow-right me-1"></i>ログアウト
            <% end %>
            <%= button_to user_registration_path,
                  method: :delete,
                  class: 'btn btn-danger px-4',
                  data: { turbo_confirm: '本当にアカウントを削除しますか？この操作は元に戻せません。' } do %>
              <i class="bi bi-trash me-1"></i>アカウント削除
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <div class="row justify-content-center g-4">
    <div class="col-md-4">
      <div class="card card-login h-100 text-center">
        <div class="card-body py-4 px-4">
          <div class="card-icon-wrap">
            <i class="bi bi-door-open-fill"></i>
          </div>
          <h5 class="card-title fw-bold">すでに登録済みの方</h5>
          <p class="card-text text-muted small mb-3">メールアドレスとパスワードでログインできます</p>
          <%= link_to new_user_session_path, class: 'btn btn-primary px-4' do %>
            <i class="bi bi-box-arrow-in-right me-1"></i>ログイン
          <% end %>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card card-register h-100 text-center">
        <div class="card-body py-4 px-4">
          <div class="card-icon-wrap">
            <i class="bi bi-person-plus-fill"></i>
          </div>
          <h5 class="card-title fw-bold">初めての方</h5>
          <p class="card-text text-muted small mb-3">メールアドレスで新規アカウントを作成できます</p>
          <%= link_to new_user_registration_path, class: 'btn btn-success px-4' do %>
            <i class="bi bi-pencil-square me-1"></i>新規登録
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
