<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>DeviseMailApp</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_include_tag 'application' %>
  </head>
  <body>
    <nav class="navbar navbar-inverse">
      <div class="container">
        <div class="navbar-header">
          <%= link_to root_path, class: 'navbar-brand' do %>
            &#9993; DeviseMailApp
          <% end %>
        </div>
        <div class="nav navbar-nav navbar-right">
          <% if user_signed_in? %>
            <p class="navbar-text"><%= current_user.email %></p>
            <%= link_to 'ログアウト', destroy_user_session_path,
                  class: 'btn btn-default navbar-btn',
                  data: { method: :delete } %>
          <% else %>
            <%= link_to '新規登録', new_user_registration_path, class: 'btn btn-default navbar-btn' %>
            <%= link_to 'ログイン', new_user_session_path, class: 'btn btn-primary navbar-btn' %>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <% flash.each do |type, message| %>
        <% alert_class = type == 'notice' ? 'alert-success' : 'alert-danger' %>
        <div class="alert <%= alert_class %> alert-dismissible" role="alert">
          <button type="button" class="close" data-dismiss="alert">
            <span>&times;</span>
          </button>
          <%= message %>
        </div>
      <% end %>
    </div>

    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
