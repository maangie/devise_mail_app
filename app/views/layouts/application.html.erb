<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>DeviseMailApp</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
      <div class="container">
        <%= link_to root_path, class: 'navbar-brand fw-bold' do %>
          <i class="bi bi-envelope-heart-fill me-1"></i> DeviseMailApp
        <% end %>
        <div class="ms-auto">
          <% if user_signed_in? %>
            <span class="navbar-text text-white me-3">
              <i class="bi bi-person-circle me-1"></i><%= current_user.email %>
            </span>
            <%= link_to destroy_user_session_path,
                  class: 'btn btn-outline-light btn-sm',
                  data: { turbo_method: :delete } do %>
              <i class="bi bi-box-arrow-right me-1"></i>ログアウト
            <% end %>
          <% else %>
            <%= link_to '新規登録', new_user_registration_path, class: 'btn btn-outline-light btn-sm me-2' %>
            <%= link_to 'ログイン', new_user_session_path, class: 'btn btn-light btn-sm' %>
          <% end %>
        </div>
      </div>
    </nav>

    <% flash.each do |type, message| %>
      <% alert_class = type == 'notice' ? 'alert-success' : 'alert-danger' %>
      <div class="alert <%= alert_class %> alert-dismissible fade show mb-0 rounded-0" role="alert">
        <div class="container">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      </div>
    <% end %>

    <main class="container py-5">
      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
